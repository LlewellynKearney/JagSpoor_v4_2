rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Existing authentication verification helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.admin == true; }

    match /animals/{animalId} { allow read: if true; allow write: if isAdmin(); }
    match /trophies/{trophyId} { allow read: if true; allow write: if isSignedIn(); }
    match /users/{userId} { allow read, write: if request.auth != null && request.auth.uid == userId; }
    match /users { allow list: if request.auth != null && request.query.limit <= 1; }

    // FIXED ROOT FIREARMS LAYER
    match /firearms/{firearmId} {
      allow read, update, delete: if isSignedIn() && request.auth.uid == resource.data.ownerId;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId;
      
      // CASCADE SUB-COLLECTION RULES DOWN THE ROOT TREE
      match /ammunition/{ammoId} {
        allow read, write: if isSignedIn();
      }
    }

    // Outfitter sub-collection tracking layout
    match /outfitter/{docId} {
      allow read, write: if isSignedIn();
      match /{subCollection}/{subDocId} { allow read, write: if isSignedIn(); }
    }

    // Global ballistic catalogues
    match /factory_ammunition/{docId} { allow read: if request.auth != null; allow write: if request.auth != null; }
    match /bullets/{docId} { allow read: if request.auth != null; allow write: if request.auth != null; }
    match /propellants/{docId} { allow read: if request.auth != null; allow write: if request.auth != null; }
  }
}
